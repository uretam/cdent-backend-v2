<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1-create-treatments" author="cdent">
        <createTable tableName="treatments">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="descripcion" type="VARCHAR(500)"/>
            <column name="precio" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="duracion_minutes" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="categoria" type="VARCHAR(100)"/>
            <column name="activo" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_creacion" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2-insert-tratamientos" author="cdent">
        <insert tableName="treatments">
            <column name="nombre" value="Limpieza dental"/>
            <column name="descripcion" value="Profilaxis y eliminación de placa"/>
            <column name="precio" valueNumeric="75.00"/>
            <column name="duracion_minutes" valueNumeric="45"/>
            <column name="categoria" value="Preventivo"/>
            <column name="activo" valueBoolean="true"/>
        </insert>
