<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1-create-pacientes" author="cdent">
        <createTable tableName="pacientes">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="apellido" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="correo" type="VARCHAR(150)">
                <constraints unique="true"/>
            </column>
            <column name="telefono" type="VARCHAR(20)"/>
            <column name="fecha_nacimiento" type="DATE"/>
            <column name="direccion" type="VARCHAR(255)"/>
            <column name="fecha_creacion" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

