<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1-create-citas" author="cdent">
        <createTable tableName="citas">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="paciente_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="odontologo_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_cita" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="estado" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="notas" type="VARCHAR(500)"/>
            <column name="fecha_creacion" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2-create-detalles-cita" author="cdent">
        <createTable tableName="detalles_cita">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cita_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="tratamiento_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="cantidad" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="precio_unitario" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="subtotal" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="notas" type="VARCHAR(255)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="detalles_cita" baseColumnNames="cita_id"
                                 referencedTableName="citas" referencedColumnNames="id"
                                 constraintName="fk_detalle_cita" onDelete="CASCADE"/>
    </changeSet>

